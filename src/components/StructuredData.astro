---
export interface Props {
  type: "BlogPosting" | "Person" | "WebSite";
  data: any;
}

const { type, data } = Astro.props;

let structuredData = {};

if (type === "BlogPosting") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.description,
    author: {
      "@type": "Person",
      name: data.author || "Nick Sondej",
      url: "https://nicksondej.com/about",
    },
    datePublished: data.pubDatetime.toISOString(),
    dateModified: data.modDatetime?.toISOString() || data.pubDatetime.toISOString(),
    publisher: {
      "@type": "Person",
      name: "Nick Sondej",
      logo: {
        "@type": "ImageObject",
        url: "https://nicksondej.com/nick-avatar.jpg",
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": data.url,
    },
    image: data.ogImage || "https://nicksondej.com/nick-avatar.jpg",
    articleSection: data.tags?.[0] || "Technology",
    keywords: data.tags?.join(", ") || "",
    wordCount: data.wordCount,
    timeRequired: data.readingTime,
  };
} else if (type === "Person") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Nick Sondej",
    url: "https://nicksondej.com",
    image: "https://nicksondej.com/nick-avatar.jpg",
    sameAs: [
      "https://github.com/nsondej",
      "https://x.com/nsondej",
      "https://www.linkedin.com/in/nick-sondej/",
    ],
    jobTitle: "Mechanical Engineer",
    description:
      "Tools, thoughts, and experiments — from a long-time mechanical engineer still figuring out what he wants to be when he grows up.",
  };
} else if (type === "WebSite") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Nick Sondej",
    url: "https://nicksondej.com",
    description:
      "Tools, thoughts, and experiments — from a long-time mechanical engineer still figuring out what he wants to be when he grows up.",
    author: {
      "@type": "Person",
      name: "Nick Sondej",
    },
    potentialAction: {
      "@type": "SearchAction",
      target: "https://nicksondej.com/search?q={search_term_string}",
      "query-input": "required name=search_term_string",
    },
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
